# systemd EnvironmentFile (no shell syntax: no `export`, no `$VAR` expansion)
# Copy this to `.env.systemd` and fill real values.
# Variable names are aligned with run_register.sh and src/shared/config/mod.rs.

# Network (run_register.sh-compatible)
SIP_BIND_IP=192.168.x.x
SIP_PORT=5060
RTP_PORT=10000
LOCAL_IP=192.168.x.x
ADVERTISED_IP=192.168.x.x

# REGISTER (src/shared/config/mod.rs:336-356)
REGISTRAR_HOST=192.168.x.x
REGISTRAR_PORT=5060
REGISTRAR_TRANSPORT=UDP
REGISTER_USER=xxxx
REGISTER_DOMAIN=192.168.x.x
REGISTER_EXPIRES=3600
REGISTER_AUTH_USER=xxxx
REGISTER_AUTH_PASSWORD=xxxx
# Optional: Contact header overrides (src/shared/config/mod.rs:345-349)
# REGISTER_CONTACT_HOST=192.168.x.x
# REGISTER_CONTACT_PORT=5060

# Recording HTTP static server (default 18080)
RECORDING_HTTP_ADDR=0.0.0.0:18080

# Logging
RUST_LOG=info

# DB (routing / call_log features; disabled if unset)
DATABASE_URL=postgres://voicebot:voicebot_dev@localhost:5432/voicebot

# Frontend integration (set only if STEER-227 remote announcement fetch is used)
# FRONTEND_BASE_URL=http://192.168.x.x:3000

# OpenAI (set only if STEER-231 is used)
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_ASR_ENABLED=true
# OPENAI_LLM_ENABLED=true
# OPENAI_TTS_ENABLED=true
# TTS_CLOUD_TIMEOUT_MS=10000

# Local LLM (optional)
# LLM_LOCAL_SERVER_URL=http://localhost:11434
# LLM_LOCAL_MODEL=llama3
# LLM_LOCAL_TIMEOUT_MS=30000
