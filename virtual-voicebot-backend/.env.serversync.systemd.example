# systemd EnvironmentFile (no shell syntax: no `export`, no `$VAR` expansion)
# Copy this to `.env.serversync.systemd` and fill real values.
# Variable names are aligned with src/shared/config/mod.rs.

# Required: DB connection (routing / sync_outbox features; backend uses PgPool/PostgresAdapter)
DATABASE_URL=postgres://voicebot:voicebot_dev@localhost:5432/voicebot

# Required: Frontend sync destination
FRONTEND_BASE_URL=http://192.168.x.x:3000

# Recommended (have defaults, but explicit values are recommended)
# src/shared/config/mod.rs:508-516
SYNC_POLL_INTERVAL_SEC=300
FRONTEND_SYNC_INTERVAL_SEC=60
SYNC_BATCH_SIZE=100
SYNC_TIMEOUT_SEC=30

# Logging
RUST_LOG=info
